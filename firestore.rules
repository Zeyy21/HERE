rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — one doc per Firebase user, holds display profile.
    //   { username, displayName, email, dob, tier, createdAt }
    // - Anyone can READ a user doc by uid (so others can resolve a username
    //   they searched for). No sensitive data here — email is needed for the
    //   username → email lookup we do at sign-in.
    // - Only the OWNING user can write their own doc.
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['username','email','tier','createdAt'])
                    && request.resource.data.username is string
                    && request.resource.data.username.size() >= 3
                    && request.resource.data.username.size() <= 32
                    && request.resource.data.tier in ['guest','regular','emperor'];
      allow update: if request.auth != null
                    && request.auth.uid == uid;
      allow delete: if false;
    }

    // usernames/{username_lowercase} — reservation index so usernames are
    // globally unique. Value is just { uid } pointing at the owner.
    //   - Anyone can READ (for "is this username taken?" and sign-in lookup)
    //   - Only the signed-in user can CREATE their own reservation
    //   - No updates or deletes (usernames are permanent for now)
    match /usernames/{name} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
